# Copy to .env and fill in. Never commit real keys.
# Use a throwaway funded testnet account only.

# Ethereum Sepolia (L1 testnet)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SEPOLIA_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY

# Base Sepolia (OP-stack L2 testnet)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY
